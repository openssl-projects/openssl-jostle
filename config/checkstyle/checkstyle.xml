<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">


    <module name="SuppressionFilter">
        <property name="file" value="${config_loc}/suppressions.xml" default=""/>
        <property name="optional" value="false"/>
    </module>


    <property name="severity" value="error"/>

    <property name="fileExtensions" value="java, properties, xml, vm, g, g4, dtd"/>

    <!-- Whitespace -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="false"/>
    </module>

    <module name="TreeWalker">
        <property name="tabWidth" value="4"/>

        <module name="LeftCurly">
            <property name="option" value="nl"/>
        </module>

        <module name="RightCurly">
            <property name="option" value="alone"/>
        </module>

        <module name="org.bouncycastle.checkstyle.DebugMethodChecker">
            <property name="contains" value="(org\.openssl\.jostle\.util\.encoders\.)*Hex\.toHexString$"/>
            <property name="ignorePackages" value="(org\.openssl\.jostle\.util\.encoders\.Hex)"/>
        </module>


        <module name="org.bouncycastle.checkstyle.DebugMethodChecker">
            <property name="contains" value="(.*(out\.print$))|(.*(out\.print)(ln$|f$)+)"/>
<!--            <property name="ignorePackages" value="(org\.bouncycastle\.test\.est\.examples\.).*"/>-->
        </module>


        <module name="org.bouncycastle.checkstyle.DebugMethodChecker">
            <property name="contains" value="(.*(System\.exit))"/>
<!--            <property name="ignorePackages" value="(org\.bouncycastle\.(mail\.smime|openpgp)\.examples\.).*|(org\.bouncycastle\.test\.est\.examples\.).*"/>-->
        </module>

    </module>

</module>

